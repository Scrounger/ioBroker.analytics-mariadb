{
    label: 'History',
    hidden: '!data.sqlInstance',
    items: {
        donation_link: {
            type: 'staticLink',
            text: 'You like the adapter? Then support me.',
            button: true,
            newLine: true,
            href: 'https://www.paypal.com/cgi-bin/webscr?cmd=_s-xclick&hosted_button_id=VWAXSTS634G88&source=url',
            style: {
                justifyContent: 'flex-start !important',
            },
            xl: 12,
            lg: 12,
            md: 12,
            sm: 12,
            xs: 12,
        },
        dividerHistories: {
            newLine: true,
            type: 'header',
            text: 'History',
            size: 2,
        },
        historyList: {
            newLine: true,
            type: 'table',
            xl: 12,
            lg: 12,
            md: 12,
            sm: 12,
            xs: 12,
            uniqueColumns: ['id'],
            confirm: {
                condition: '!_alive',
                title: 'Attention!',
                text: 'This selection is only possible with a running instance!',
                ok: 'Got it!',
                cancel: 'cancel',
                type: 'warning',
            },
            items: [
                {
                    attr: 'id',
                    type: 'autocompleteSendTo',
                    title: 'Datapoints',
                    sort: true,
                    filter: true,
                    noMultiEdit: true,
                    jsonData: '{}', // ToDo: sollte irgendwann mal der Bug mit globalData und JSON.stringify behoben sein, dann hier anpassen
                    command: 'getDatapointsList',
                    validator: '!!data.id',
                    validatorNoSaveOnError: true,
                    validatorErrorText: 'mandatory input',
                    multiple: true,
                },
                {
                    attr: 'decimals',
                    type: 'number',
                    title: 'decimals',
                    min: 0,
                    max: 10,
                    step: 1,
                    default: 3,
                    width: 85,
                },
                {
                    attr: 'days',
                    type: 'number',
                    title: 'days',
                    min: 0,
                    max: 99,
                    step: 1,
                    defaultFunc: {
                        func: 'globalData.historyDefaultDays',
                        alsoDependsOn: ['historyDefaultDays'],
                    },
                    width: 85,
                },
                {
                    attr: 'weeks',
                    type: 'number',
                    title: 'weeks',
                    min: 0,
                    max: 99,
                    step: 1,
                    defaultFunc: {
                        func: 'globalData.historyDefaultWeeks',
                        alsoDependsOn: ['historyDefaultWeeks'],
                    },
                    width: 85,
                },
                {
                    attr: 'months',
                    type: 'number',
                    title: 'months',
                    min: 0,
                    max: 99,
                    step: 1,
                    defaultFunc: {
                        func: 'globalData.historyDefaultMonths',
                        alsoDependsOn: ['historyDefaultMonths'],
                    },
                    width: 85,
                },
                {
                    attr: 'years',
                    type: 'number',
                    title: 'years',
                    min: 0,
                    max: 99,
                    step: 1,
                    defaultFunc: {
                        func: 'globalData.historyDefaultYears',
                        alsoDependsOn: ['historyDefaultYears'],
                    },
                    width: 85,
                },
            ],
        },
    },
}
