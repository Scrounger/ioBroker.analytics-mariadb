{
    label: 'History',
    hidden: '!data.sqlInstance',
    items: {
        donation_link: {
            type: 'staticLink',
            text: 'You like the adapter? Then support me.',
            button: true,
            newLine: true,
            href: 'https://www.paypal.com/cgi-bin/webscr?cmd=_s-xclick&hosted_button_id=VWAXSTS634G88&source=url',
            style: {
                justifyContent: 'flex-start !important',
            },
            xl: 12,
            lg: 12,
            md: 12,
            sm: 12,
            xs: 12,
        },
        dividerHistories: {
            newLine: true,
            type: 'header',
            text: 'History',
            size: 2,
        },
        historyList: {
            newLine: true,
            type: 'table',
            xl: 12,
            lg: 12,
            md: 12,
            sm: 12,
            xs: 12,
            uniqueColumns: ['id'],
            confirm: {
                condition: '!_alive',
                title: 'Attention!',
                text: 'This selection is only possible with a running instance!',
                ok: 'Got it!',
                cancel: 'cancel',
                type: 'warning',
            },
            items: [
                {
                    attr: 'id',
                    type: 'autocompleteSendTo',
                    title: 'Datapoints',
                    sort: true,
                    filter: true,
                    noMultiEdit: true,
                    jsonData: '{"dataNumber": ${JSON.stringify(globalData.datapointsNumberList)}, "dataBoolean": ${JSON.stringify(globalData.datapointsBooleanList)}}',
                    command: 'getDatapointsList',
                    validator: '!!data?.id && (globalData?.datapointsNumberList?.some(dp => data?.id?.includes(dp?.idChannelTarget)) || globalData?.datapointsBooleanList?.some(dp => data?.id?.includes(dp?.idChannelTarget)))',
                    validatorNoSaveOnError: true,
                    validatorErrorText: 'mandatory input',
                    disabled: '!globalData.datapointsNumberList.find(dp => data.id.includes(dp.idChannelTarget))?.enable && !globalData.datapointsBooleanList.find(dp => data.id.includes(dp.idChannelTarget))?.enable',
                },
                {
                    attr: 'debounce',
                    type: 'number',
                    title: 'De-bounce time',
                    unit: 's',
                    min: 0,
                    max: 60,
                    step: 1,
                    defaultFunc: {
                        func: 'globalData.historyDefaultUpdateDeBounce',
                        alsoDependsOn: ['historyDefaultUpdateDeBounce'],
                    },
                    width: 100,
                    disabled: '!globalData.datapointsNumberList.find(dp => data.id.includes(dp.idChannelTarget))?.enable && !globalData.datapointsBooleanList.find(dp => data.id.includes(dp.idChannelTarget))?.enable',
                },
                {
                    attr: 'decimals',
                    type: 'number',
                    title: 'decimals',
                    min: 0,
                    max: 10,
                    step: 1,
                    default: 3,
                    width: 85,
                    hidden: '!data?.id?.endsWith(".total") || data?.id === undefined || data?.id === "" || data?.id === null',
                    disabled: '!globalData.datapointsNumberList.find(dp => data.id.includes(dp.idChannelTarget))?.enable && !globalData.datapointsBooleanList.find(dp => data.id.includes(dp.idChannelTarget))?.enable',
                },
                {
                    attr: 'day',
                    type: 'number',
                    title: 'daysShort',
                    min: 0,
                    max: 99,
                    step: 1,
                    defaultFunc: {
                        func: 'globalData.historyDefaultDays',
                        alsoDependsOn: ['historyDefaultDays'],
                    },
                    tooltip: 'days',
                    disabled: '!globalData.datapointsNumberList.find(dp => data.id.includes(dp.idChannelTarget))?.enable && !globalData.datapointsBooleanList.find(dp => data.id.includes(dp.idChannelTarget))?.enable',
                    width: 72,
                    style: {
                        minWidth: '36px',
                    },
                },
                {
                    attr: 'week',
                    type: 'number',
                    title: 'weeksShort',
                    min: 0,
                    max: 99,
                    step: 1,
                    defaultFunc: {
                        func: 'globalData.historyDefaultWeeks',
                        alsoDependsOn: ['historyDefaultWeeks'],
                    },
                    tooltip: 'weeks',
                    disabled: '!globalData.datapointsNumberList.find(dp => data.id.includes(dp.idChannelTarget))?.enable && !globalData.datapointsBooleanList.find(dp => data.id.includes(dp.idChannelTarget))?.enable',
                    width: 72,
                    style: {
                        minWidth: '36px',
                    },
                },
                {
                    attr: 'month',
                    type: 'number',
                    title: 'monthsShort',
                    min: 0,
                    max: 99,
                    step: 1,
                    defaultFunc: {
                        func: 'globalData.historyDefaultMonths',
                        alsoDependsOn: ['historyDefaultMonths'],
                    },
                    tooltip: 'months',
                    disabled: '!globalData.datapointsNumberList.find(dp => data.id.includes(dp.idChannelTarget))?.enable && !globalData.datapointsBooleanList.find(dp => data.id.includes(dp.idChannelTarget))?.enable',
                    width: 72,
                    style: {
                        minWidth: '36px',
                    },
                },
                {
                    attr: 'year',
                    type: 'number',
                    title: 'yearsShort',
                    min: 0,
                    max: 99,
                    step: 1,
                    defaultFunc: {
                        func: 'globalData.historyDefaultYears',
                        alsoDependsOn: ['historyDefaultYears'],
                    },
                    tooltip: 'years',
                    disabled: '!globalData.datapointsNumberList.find(dp => data.id.includes(dp.idChannelTarget))?.enable && !globalData.datapointsBooleanList.find(dp => data.id.includes(dp.idChannelTarget))?.enable',
                    width: 72,
                    style: {
                        minWidth: '36px',
                    },
                },
                {
                    attr: 'idContractType',
                    type: 'autocompleteSendTo',
                    title: 'Costs',
                    sort: true,
                    filter: true,
                    noMultiEdit: true,
                    jsonData: '{"data": ${JSON.stringify(globalData.costsContractTypesList)}}',
                    command: 'getCostsContractTypes',
                    validator: '(data?.idContractType === undefined || data?.idContractType === "" || data?.idContractType === null) || (!!data?.idContractType && globalData?.costsContractTypesList?.some(ct => ct?.id === data?.idContractType))',
                    validatorNoSaveOnError: true,
                    validatorErrorText: 'mandatory input',
                    hidden: '!data?.id?.endsWith(".total") || data?.id === undefined || data?.id === "" || data?.id === null',
                    width: 200,
                    disabled: '!globalData.datapointsNumberList.find(dp => data.id.includes(dp.idChannelTarget))?.enable && !globalData.datapointsBooleanList.find(dp => data.id.includes(dp.idChannelTarget))?.enable',
                },
                {
                    attr: 'costSumOptions',
                    type: 'select',
                    title: 'Total costs',
                    multiple: true,
                    options: [
                        { value: 'variableCosts', label: 'variable costs' },
                        { value: 'basicPrice', label: 'basic fee' },
                        { value: 'bonusPrice', label: 'bonus' },
                    ],
                    validator: 'data.idContractType && data.costSumOptions && data.costSumOptions.length > 0',
                    validatorNoSaveOnError: true,
                    validatorErrorText: 'you have to select minimum one option',
                    hidden: '(!data.id.endsWith(".total") || !data.idContractType) || (data.id === undefined || data.id === "" || data.id === null)',
                    width: 180,
                    disabled: '!globalData.datapointsNumberList.find(dp => data.id.includes(dp.idChannelTarget))?.enable && !globalData.datapointsBooleanList.find(dp => data.id.includes(dp.idChannelTarget))?.enable',
                },
                {
                    attr: 'debug',
                    type: 'checkbox',
                    title: 'debug',
                    default: false,
                    width: 0,
                    disabled: '!globalData.datapointsNumberList.find(dp => data.id.includes(dp.idChannelTarget))?.enable && !globalData.datapointsBooleanList.find(dp => data.id.includes(dp.idChannelTarget))?.enable',
                },
            ],
        },
    },
}
