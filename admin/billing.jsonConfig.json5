{
    label: 'billing period',
    hidden: '!data.sqlInstance',
    items: {
        donation_link: {
            type: 'staticLink',
            text: 'You like the adapter? Then support me.',
            button: true,
            newLine: true,
            href: 'https://www.paypal.com/cgi-bin/webscr?cmd=_s-xclick&hosted_button_id=VWAXSTS634G88&source=url',
            style: {
                justifyContent: 'flex-start !important',
            },
            xl: 12,
            lg: 12,
            md: 12,
            sm: 12,
            xs: 12,
        },
        dividerCostsTypes: {
            newLine: true,
            type: 'header',
            text: 'billing period',
            size: 2,
        },
        billingList: {
            newLine: true,
            type: 'table',
            xl: 12,
            lg: 12,
            md: 12,
            sm: 12,
            xs: 12,
            confirm: {
                condition: '!_alive',
                title: 'Attention!',
                text: 'This selection is only possible with a running instance!',
                ok: 'Got it!',
                cancel: 'cancel',
                type: 'warning',
            },
            items: [
                {
                    attr: 'id',
                    type: 'autocompleteSendTo',
                    title: 'Datapoints',
                    sort: true,
                    filter: true,
                    noMultiEdit: true,
                    jsonData: '{"history": ${JSON.stringify(globalData.historyList)}, "datapoints": ${JSON.stringify(globalData.datapointsNumberList)}}',
                    command: 'getBillingList',
                    validator: 'data.id && (globalData.datapointsNumberList.some(dp => data.id.includes(dp.idChannelTarget))) && globalData.historyList.find(dp => data.id === dp.id)?.idContractType',
                    validatorNoSaveOnError: true,
                    validatorErrorText: 'mandatory input',
                    disabled: '!globalData.datapointsNumberList.find(dp => data.id.includes(dp.idChannelTarget)).enable',
                },
                {
                    attr: 'provider',
                    type: 'text',
                    title: 'name of provider',
                    sort: true,
                    filter: true,
                    disabled: '!globalData.datapointsNumberList.find(dp => data.id.includes(dp.idChannelTarget)).enable',
                },
                {
                    attr: 'start',
                    type: 'datePicker',
                    title: 'start date',
                    sort: true,
                    validator: '!!data.start && new Date(data.start) < new Date(data.end)',
                    validatorNoSaveOnError: true,
                    validatorErrorText: 'mandatory input',
                    width: 180,
                    disabled: '!globalData.datapointsNumberList.find(dp => data.id.includes(dp.idChannelTarget)).enable',
                },
                {
                    attr: 'end',
                    type: 'datePicker',
                    title: 'end date',
                    sort: true,
                    validator: '!!data.end && new Date(data.end) > new Date(data.start)',
                    validatorNoSaveOnError: true,
                    validatorErrorText: 'mandatory input',
                    width: 180,
                    disabled: '!globalData.datapointsNumberList.find(dp => data.id.includes(dp.idChannelTarget)).enable',
                },
                {
                    attr: 'prePayment',
                    type: 'number',
                    title: 'pre payment of period',
                    width: 140,
                    min: -99999999,
                    max: 99999999,
                    disabled: '!globalData.datapointsNumberList.find(dp => data.id.includes(dp.idChannelTarget)).enable',
                },
                {
                    attr: 'fixCostsDaily',
                    type: 'checkbox',
                    title: 'fix costs on daily basis',
                    default: true,
                    width: 150,
                },
                {
                    attr: 'debug',
                    type: 'checkbox',
                    title: 'debug',
                    default: false,
                    width: 0,
                },
            ],
        },
    },
}
