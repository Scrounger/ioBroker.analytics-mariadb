{
    label: 'Costs',
    hidden: '!data.sqlInstance',
    items: {
        donation_link: {
            type: 'staticLink',
            text: 'You like the adapter? Then support me.',
            button: true,
            newLine: true,
            href: 'https://www.paypal.com/cgi-bin/webscr?cmd=_s-xclick&hosted_button_id=VWAXSTS634G88&source=url',
            style: {
                justifyContent: 'flex-start !important',
            },
            xl: 12,
            lg: 12,
            md: 12,
            sm: 12,
            xs: 12,
        },
        dividerCostsTypes: {
            newLine: true,
            type: 'header',
            text: 'contract types',
            size: 2,
        },
        costsContractTypesList: {
            newLine: true,
            type: 'table',
            xl: 12,
            lg: 12,
            md: 12,
            sm: 12,
            xs: 12,
            uniqueColumns: ['id'],
            compact: true,
            items: [
                {
                    attr: 'id',
                    type: 'text',
                    title: 'contract type',
                    sort: true,
                    filter: true,
                    validator: '!!data.id',
                    validatorNoSaveOnError: true,
                    validatorErrorText: 'mandatory input',
                },
                {
                    attr: 'calcFormula',
                    type: 'text',
                    title: 'Formula for calculating variable costs',
                    sort: true,
                    filter: true,
                    validator: '!!data.calcFormula && !!data.calcFormula.includes("#val")',
                    validatorNoSaveOnError: true,
                    validatorErrorText: 'mandatory input',
                },
                {
                    attr: 'currency',
                    type: 'text',
                    title: 'currency',
                    sort: true,
                    filter: true,
                    defaultFunc: {
                        func: '_system.currency',
                        alsoDependsOn: [],
                    },
                    width: 140,
                },
                {
                    attr: 'debug',
                    type: 'checkbox',
                    title: 'debug',
                    default: false,
                    width: 0,
                },
            ],
        },
        dividerCostsData: {
            newLine: true,
            type: 'header',
            text: 'contract data',
            size: 2,
        },
        costsContractDataList: {
            newLine: true,
            type: 'table',
            xl: 12,
            lg: 12,
            md: 12,
            sm: 12,
            xs: 12,
            // uniqueColumns: ['idType'],
            compact: true,
            items: [
                {
                    attr: 'idContractType',
                    type: 'autocompleteSendTo',
                    title: 'contract type',
                    sort: true,
                    filter: true,
                    allowAddByFilter: true,
                    noMultiEdit: true,
                    jsonData: '{"data": ${JSON.stringify(globalData.costsContractTypesList)}}',
                    command: 'getCostsContractTypes',
                    validator: '!!data.idContractType && !!globalData.costsContractTypesList.some(ct => ct.id === data.idContractType);',
                    validatorNoSaveOnError: true,
                    validatorErrorText: 'mandatory input',
                    width: 280,
                },
                {
                    attr: 'provider',
                    type: 'text',
                    title: 'name of provider',
                    sort: true,
                    filter: true,
                },
                {
                    attr: 'start',
                    type: 'datePicker',
                    title: 'start date',
                    sort: true,
                    validator: '!!data.start && new Date(data.start) < new Date(data.end)',
                    validatorNoSaveOnError: true,
                    validatorErrorText: 'mandatory input',
                    width: 180,
                    style: {
                        minWidth: '120px',
                    },
                },
                {
                    attr: 'end',
                    type: 'datePicker',
                    title: 'end date',
                    sort: true,
                    validator: '!!data.end && new Date(data.end) > new Date(data.start)',
                    validatorNoSaveOnError: true,
                    validatorErrorText: 'mandatory input',
                    width: 180,
                    style: {
                        minWidth: '120px',
                    },
                },
                {
                    attr: 'variableCosts',
                    type: 'chips',
                    title: 'variable costs',
                    sort: true,
                    validator: '!!data.variableCosts?.length && data.variableCosts.every(v => /^[\\w]+:(\\d+([.,]\\d+)?)$/.test(v)) && ((f => f.every(v => data.variableCosts.some(vc => vc.startsWith(v + ":"))))((globalData.costsContractTypesList.find(c => c.id === data.idContractType)?.calcFormula.match(/#[\\w]+/g) ?? []).map(v=>v.slice(1)).filter(v=>"val"!==v))) && data.variableCosts.every(v => (globalData.costsContractTypesList.find(c => c.id === data.idContractType)?.calcFormula ?? "").includes(`#${v.split(":")[0]}`))',
                    validatorNoSaveOnError: true,
                    validatorErrorText: 'all variables from calculation formula of contract type must be included',
                },
                {
                    attr: 'basicPrice',
                    type: 'number',
                    title: 'basic fee per year',
                    min: 0,
                    default: 0,
                    width: 120,
                },
                {
                    attr: 'bonusPrice',
                    type: 'number',
                    title: 'bonus per year',
                    min: 0,
                    default: 0,
                    width: 120,
                },
            ],
        },
    },
}
