{
  "name": "iobroker.analytics-mariadb",
  "version": "0.0.5",
  "description": "Analytics adapter for processing data stored in MariaDB",
  "author": {
    "name": "Scrounger",
    "email": "scrounger@gmx.net"
  },
  "contributors": [],
  "homepage": "https://github.com/Scrounger/ioBroker.analytics-mariadb",
  "license": "MIT",
  "keywords": [
    "mariadb",
    "sql",
    "analytics",
    "energy",
    "costs"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Scrounger/ioBroker.analytics-mariadb.git"
  },
  "engines": {
    "node": ">= 20"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.3.1",
    "lodash": "^4.17.21",
    "moment": "^2.30.1",
    "mathjs": "^15.1.1",
    "node-schedule": "^2.1.1"
  },
  "devDependencies": {
    "@alcalzone/release-script": "^5.1.1",
    "@alcalzone/release-script-plugin-iobroker": "^5.1.2",
    "@alcalzone/release-script-plugin-license": "^5.1.1",
    "@alcalzone/release-script-plugin-manual-review": "^5.1.1",
    "@iobroker/adapter-dev": "^1.5.0",
    "@iobroker/eslint-config": "^2.2.0",
    "@iobroker/testing": "^5.2.2",
    "@types/lodash": "^4.17.24",
    "@types/node": "^22.5.5",
    "@types/ws": "^8.18.1",
    "@types/node-schedule": "^2.1.8",
    "rimraf": "^6.1.3",
    "source-map-support": "^0.5.21",
    "ts-node": "^10.9.2",
    "tsc-watch": "^7.2.0",
    "typescript": "~5.9"
  },
  "type": "module",
  "main": "build/main.js",
  "files": [
    "admin{,/!(src)/**}/!(tsconfig|tsconfig.*|.eslintrc).{json,json5}",
    "admin{,/!(src)/**}/*.{html,css,png,svg,jpg,js}",
    "build/",
    "www/",
    "io-package.json",
    "LICENSE"
  ],
  "scripts": {
    "prebuild": "rimraf build",
    "build": "tsc",
    "build-watch": "clear && tsc-watch --noClear --onSuccess 'iobroker restart analytics-mariadb'",
    "watch": "build-adapter ts --watch",
    "prebuild:ts": "rimraf build",
    "build:ts": "build-adapter ts",
    "watch:ts": "build-adapter ts --watch",
    "test:ts": "mocha --config test/mocharc.custom.json src/**/*.test.ts",
    "test:package": "mocha test/package --exit",
    "test:integration": "mocha test/integration --exit",
    "test": "npm run test:ts && npm run test:package",
    "check": "tsc --noEmit",
    "lint": "eslint -c eslint.config.mjs .",
    "translate": "translate-adapter",
    "release": "release-script"
  },
  "bugs": {
    "url": "https://github.com/Scrounger/ioBroker.analytics-mariadb/issues"
  },
  "readmeFilename": "README.md"
}